; ModuleID = 'glyim_out'
source_filename = "glyim_out"

declare i64 @write(i32, ptr, i64)

declare void @abort()

declare i32 @printf(ptr, ...)

define void @glyim_println_int(i64 %0) {
entry:
  %printf_call = call i32 (ptr, ...) @printf([6 x i8] c"%lld\0A\00", i64 %0)
  ret void
}

define void @glyim_println_str({ ptr, i64 } %0) {
entry:
  %data = extractvalue { ptr, i64 } %0, 0
  %printf_call = call i32 (ptr, ...) @printf([4 x i8] c"%s\0A\00", ptr %data)
  ret void
}

define void @glyim_assert_fail(ptr %0, i64 %1) {
entry:
  %write_stderr = call i64 @write(i32 2, ptr %0, i64 %1)
  call void @abort()
  unreachable
}

declare ptr @malloc(i64)

declare void @free(ptr)

define ptr @glyim_alloc(i64 %0) {
entry:
  %raw_ptr = call ptr @malloc(i64 %0)
  %is_null = icmp eq ptr %raw_ptr, null
  br i1 %is_null, label %oom, label %ok

oom:                                              ; preds = %entry
  unreachable

ok:                                               ; preds = %entry
  ret ptr %raw_ptr
}

define void @glyim_free(ptr %0) {
entry:
  call void @free(ptr %0)
  ret void
}

define i32 @main() {
entry:
  ret i32 42
}
