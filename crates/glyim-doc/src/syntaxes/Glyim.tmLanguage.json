{
  "name": "Glyim",
  "scopeName": "source.glyim",
  "fileTypes": ["g"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#macros" },
    { "include": "#attributes" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#constants" },
    { "include": "#operators" },
    { "include": "#functions" },
    { "include": "#numbers" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.glyim",
          "match": "//.*$"
        },
        {
          "name": "comment.block.glyim",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "strings": {
      "name": "string.quoted.double.glyim",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.glyim",
          "match": "\\\\."
        }
      ]
    },
    "macros": {
      "name": "meta.macro.glyim",
      "match": "@[a-zA-Z_][a-zA-Z0-9_]*"
    },
    "attributes": {
      "name": "meta.attribute.glyim",
      "match": "#\\[[a-zA-Z_][a-zA-Z0-9_]*(?:\\([^)]*\\))?\\]"
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.glyim",
          "match": "\\b(fn|struct|enum|impl|extern|let|mut|if|else|match|return|pub|as|for|in|while|use|self)\\b"
        },
        {
          "name": "keyword.operator.glyim",
          "match": "(=>|->|==|!=|<=|>=|&&|\\|\\||\\+|-|\\*|/|%|=|!|&|\\||<|>)"
        },
        {
          "name": "storage.type.glyim",
          "match": "\\b(i64|f64|bool|Str|str|Int|Float|Bool|Option|Result)\\b"
        },
        {
          "name": "constant.language.glyim",
          "match": "\\b(true|false|None|Some|Ok|Err)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "entity.name.type.glyim",
          "match": "\\b[A-Z][a-zA-Z0-9_]*\\b"
        },
        {
          "name": "storage.type.pointer.glyim",
          "match": "\\*const\\s+[a-zA-Z_][a-zA-Z0-9_]*|\\*mut\\s+[a-zA-Z_][a-zA-Z0-9_]*"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.numeric.integer.glyim",
          "match": "\\b[0-9]+\\b(?!\\.)"
        },
        {
          "name": "constant.numeric.float.glyim",
          "match": "\\b[0-9]+\\.[0-9]+\\b"
        },
        {
          "name": "constant.language.boolean.glyim",
          "match": "\\b(true|false)\\b"
        }
      ]
    },
    "operators": {
      "name": "keyword.operator.glyim",
      "match": "(=>|->|==|!=|<=|>=|&&|\\|\\||\\+|-|\\*|/|\\%|=|!|&|\\||<|>)"
    },
    "functions": {
      "patterns": [
        {
          "name": "entity.name.function.glyim",
          "match": "\\b[a-z_][a-zA-Z0-9_]*\\s*(?=\\()"
        },
        {
          "name": "support.function.builtin.glyim",
          "match": "\\b(println|assert|write|read|open|close|__glyim_alloc|__glyim_free|__glyim_hash_bytes|__glyim_hash_seed|__size_of|__ptr_offset|abort|main)\\b"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.glyim",
          "match": "\\b[0-9]+\\.[0-9]+\\b"
        },
        {
          "name": "constant.numeric.integer.glyim",
          "match": "\\b[0-9]+\\b"
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "name": "variable.other.glyim",
          "match": "\\b[a-z_][a-zA-Z0-9_]*\\b"
        },
        {
          "name": "variable.parameter.glyim",
          "match": "\\b[a-z_][a-zA-Z0-9_]*\\b(?=\\s*[,)])"
        }
      ]
    }
  }
}
