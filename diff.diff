+    let hir = glyim_hir::lower(&parse_out.ast, &mut interner);
+    let mut typeck = glyim_typeck::TypeChecker::new(interner);
+    if let Err(errs) = typeck.check(&hir) {
+        let mut output = String::new();
+        for e in &errs {
