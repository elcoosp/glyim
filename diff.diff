@@ -28,7 +28,7 @@ jobs:
           wget https://apt.llvm.org/llvm.sh
           chmod +x llvm.sh
           sudo ./llvm.sh 22
-          sudo apt-get install -y llvm-22-dev libclang-22-dev
+          sudo apt-get install -y llvm-22-dev libclang-22-dev libpolly-22-dev
 
       - name: Set LLVM environment
         run: |
@@ -39,3 +39,23 @@ jobs:
       - run: cargo clippy --workspace -- -D warnings
       - run: cargo fmt --all -- --check
       - run: python3 scripts/check_file_sizes.py
+
+
+mutants:
+  name: Mutation Testing
+  runs-on: ubuntu-latest
+  steps:
+    - uses: actions/checkout@v6
+    - uses: dtolnay/rust-toolchain@stable
+    - name: Run cargo-mutants
+      run: cargo mutants -j 4 --workspace --fail-under 90
+
+  miri:
+    name: Miri UB check
+    runs-on: ubuntu-latest
+    steps:
+      - uses: actions/checkout@v6
+      - uses: dtolnay/rust-toolchain@nightly
+        with:
+          components: miri
+      - run: cargo miri test --workspace -- --skip integration --skip fuzz
