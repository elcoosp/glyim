+    pub fn new() -> Vec<T> { Vec { data: 0 as *mut T, len: 0, cap: 0 } }
+    pub fn get(self: Vec<T>, index: i64) -> T {
+        if index >= self.len {
+            0 as T
+        } else {
+            let elem_size = __size_of::<T>();
+            let ptr = __ptr_offset(self.data as *mut u8, index * elem_size) as *mut T;
+            *ptr
+        }
+    }
