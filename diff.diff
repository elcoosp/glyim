+    let body = get_main_body(&hir, &interner);
+    let has_enum = match body {
+        HirExpr::Block { stmts, .. } => stmts.iter().any(|s| {
+            matches!(
+                s,
+                HirStmt::LetPat {
+                    value: HirExpr::EnumVariant { .. },
+                    ..
+                }
+            )
+        }),
+        _ => false,
