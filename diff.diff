+// ── Scope / binding tests ────────────────────────────────────
+#[test]
+fn lookup_unbound_returns_none() {
+    let mut tc = TypeChecker::new(Interner::new());
+    let missing = tc.interner.intern("nonexistent");
+    assert_eq!(tc.lookup_binding(&missing), None);
+}
