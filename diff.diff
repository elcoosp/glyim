+    let mut tc = TypeChecker::new(Interner::new());
+    let x = tc.interner.intern("x");
+    tc.insert_binding(x, HirType::Int);
+    let inner_result = tc.with_scope(|tc| {
+        let y = tc.interner.intern("y");
+        tc.insert_binding(y, HirType::Str);
+        tc.lookup_binding(&y)
+    });
