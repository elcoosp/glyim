+                tracing::debug!(
+                    "[resolve_struct_type] Generic: base_str={} args_str={} mangled={}",
+                    base_str,
+                    args_str,
+                    mangled_str
+                );
+                if let Some(_found) = self.interner.resolve_symbol(&mangled_str) {
+                    tracing::debug!("[resolve_struct_type] FOUND in interner");
