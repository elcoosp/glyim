+    match body {
+        HirExpr::Block { stmts, .. } => {
+            assert!(
+                stmts.iter().any(|s| matches!(
+                    s,
+                    HirStmt::LetPat {
+                        value: HirExpr::Match { .. },
+                        ..
+                    }
