+    cg.set_target(target_triple);
+    cg.generate(&hir)?;
+    let tmp_dir = tempfile::tempdir().map_err(|e| e.to_string())?;
+    let obj_path = tmp_dir.path().join("output.o");
+    cg.write_object_file(&obj_path)?;
