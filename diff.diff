+    global.set_linkage(inkwell::module::Linkage::Private);
+    let zero = context.i32_type().const_int(0, false);
+    unsafe {
+        global
+            .as_pointer_value()
+            .const_in_bounds_gep(ty, &[zero, zero])
+    }
+}
