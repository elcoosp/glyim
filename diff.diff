+#[test]
+fn lower_none_expr() {
+    let (hir, interner) = lower_source("main = () => None");
+    let body = get_main_body(&hir, &interner);
+    let val = expr_value(body);
+    match val {
+        HirExpr::EnumVariant {
+            variant_name, args, ..
+        } if interner.resolve(*variant_name) == "None" && args.is_empty() => {}
+        _ => panic!("expected None variant, got {:?}", val),
