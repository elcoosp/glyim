{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Glyim",
  "patterns": [
    { "include": "#keywords" },
    { "include": "#strings" },
    { "include": "#comments" },
    { "include": "#numbers" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "keywords": {
      "patterns": [{
        "name": "keyword.control.glyim",
        "match": "\\b(fn|struct|enum|let|if|else|match|return|use|true|false|pub|extern|as|impl|for|while|mut|self)\\b"
      }]
    },
    "strings": {
      "name": "string.quoted.double.glyim",
      "begin": "\"",
      "end": "\"",
      "patterns": [{
        "name": "constant.character.escape.glyim",
        "match": "\\\\."
      }]
    },
    "comments": {
      "patterns": [
        { "name": "comment.line.double-slash.glyim", "match": "//.*" },
        { "name": "comment.block.glyim", "begin": "/\\*", "end": "\\*/" }
      ]
    },
    "numbers": {
      "patterns": [
        { "name": "constant.numeric.float.glyim", "match": "\\b[0-9]+\\.[0-9]+\\b" },
        { "name": "constant.numeric.integer.glyim", "match": "\\b[0-9]+\\b" }
      ]
    },
    "identifiers": {
      "patterns": [
        { "name": "entity.name.function.glyim", "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\s*\\(" }
      ]
    }
  },
  "scopeName": "source.glyim"
}
