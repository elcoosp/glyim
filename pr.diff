 /// Generate HTML documentation from HIR, including doc comments rendered as GitHub Flavored Markdown.
+fn format_fn_signature(f: &glyim_hir::node::HirFn, interner: &Interner) -> String {
+    let params: Vec<String> = f
+        .params
